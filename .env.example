# 选股雷达实验室 - 环境变量配置模板
# 复制为 .ai_env 或通过 systemd Environment= 注入，切勿提交真实值

# ─── 选股引擎（iwencai/同花顺 openapi）───
IWENCAI_API_KEY="your-iwencai-key"

# ─── 投资作战室 API（如部署）───
INVEST_API_TOKEN="your-invest-api-token"

# ─── VIP 账户系统（account_server.py, 端口 5060）───
# 管理员用户名（该用户登录后可访问 /account-api/admin/*）
ACCOUNT_ADMIN="walle"
# Session 签名密钥（必须随机生成：python3 -c "import secrets;print(secrets.token_hex(32))"）
ACCOUNT_SECRET_KEY="generate-a-random-32byte-hex"

# ─── AI 研报（ai_research.py / agent_council.py）───
# 任选一个 provider，优先级：DEEPSEEK > ZHIPU > BIGMODEL > OPENAI
DEEPSEEK_API_KEY="your-deepseek-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
ZHIPU_API_KEY="your-zhipu-key"
ZHIPU_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
LANGCHAIN_MODEL_NAME="deepseek-chat"
LANGCHAIN_TEMPERATURE="0.3"
LANGCHAIN_PROVIDER="deepseek"

# ─── 飞书推送（可选）───
FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook"
